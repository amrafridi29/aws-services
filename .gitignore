# =========================
# Terraform .gitignore
# =========================

# Local .terraform directories
**/.terraform/*
.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files that may contain secrets
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform CLI config files
.terraformrc
terraform.rc

# Ignore plan output files
*.tfplan
*.plan
plan.out

# Ignore lock info backup/editor temp files
*.backup
*.tmp
*.swp
*.swo
*~

# Optional: Ignore sensitive env files
.env
.env.*

# Optional: Ignore IDE/editor files
.vscode/
.idea/
*.iml

# Optional: macOS / Linux / Windows junk
.DS_Store
Thumbs.db
